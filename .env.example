AI_GATEWAY_API_KEY=

# Optional local audit defaults for login-protected apps.
QA_LOGIN_URL=
QA_USERNAME=
QA_PASSWORD=
QA_USERNAME_SELECTOR=
QA_PASSWORD_SELECTOR=
QA_SUBMIT_SELECTOR=
QA_MAX_PAGES=5
QA_MAX_CLICKS_PER_PAGE=8
QA_ARTIFACT_DIR=
QA_REPORT_ROOT=

# Optional: Vercel deployment webhook secret. Used to verify x-vercel-signature.
# Manual calls can also pass this as Bearer auth, x-agentic-web-qa-secret, or ?secret=.
AGENTIC_WEB_QA_WEBHOOK_SECRET=

# Optional: tune audits started by the Vercel webhook channel.
AGENTIC_WEB_QA_MAX_PAGES=5
AGENTIC_WEB_QA_MAX_CLICKS_PER_PAGE=8
AGENTIC_WEB_QA_AUDIT_PRODUCTION=false

# Optional: bypass Vercel Deployment Protection for preview URLs.
VERCEL_AUTOMATION_BYPASS_SECRET=

# Optional: native Vercel Checks API publishing. Must be an OAuth2 integration token.
VERCEL_CHECKS_OAUTH_TOKEN=
VERCEL_TEAM_ID=
VERCEL_TEAM_SLUG=

# Optional: Vercel Connect GitHub connector for publishing PR reports from the Eve agent.
GITHUB_CONNECTOR=github/agentic-web-qa-github
GITHUB_CONNECT_INSTALLATION_ID=
